import { useState, useRef, useEffect, useCallback } from "react";
import { motion, AnimatePresence } from "framer-motion";
import { Send, ArrowLeft, Plus, MessageSquare, PanelLeftClose, PanelLeft, Trash2 } from "lucide-react";
import { useNavigate } from "react-router-dom";
import { useProfile } from "@/context/ProfileContext";

interface Message {
  id: string;
  role: "user" | "assistant";
  content: string;
}

interface ChatSession {
  id: string;
  title: string;
  messages: Message[];
  createdAt: number;
}

const formatDate = (ts: number) => {
  const d = new Date(ts);
  const now = new Date();
  const diff = now.getTime() - d.getTime();
  if (diff < 86400000) return "Today";
  if (diff < 172800000) return "Yesterday";
  return d.toLocaleDateString("en-US", { month: "short", day: "numeric" });
};

const getSessionStorageKey = (email?: string) => `orch-sessions-${email || "guest"}`;

const saveSessions = (sessions: ChatSession[], email?: string) => {
  if (!email) return;
  localStorage.setItem(getSessionStorageKey(email), JSON.stringify(sessions));
};

const loadSessions = (email?: string): ChatSession[] => {
  try {
    const saved = localStorage.getItem(getSessionStorageKey(email));
    const parsed = saved ? JSON.parse(saved) : [];
    if (!Array.isArray(parsed)) return [];
    return parsed.sort((a, b) => b.createdAt - a.createdAt);
  } catch {
    return [];
  }
};

const tryParseJson = (value: string) => {
  try {
    return JSON.parse(value);
  } catch {
    return undefined;
  }
};

const renderStructuredContent = (data: any): JSX.Element => {
  if (Array.isArray(data)) {
    return (
      <ul className="list-disc list-inside space-y-1 text-sm">
        {data.map((item, index) => (
          <li key={index} className="leading-5">
            {renderStructuredContent(item)}
          </li>
        ))}
      </ul>
    );
  }

  if (typeof data === "object" && data !== null) {
    return (
      <div className="space-y-3 text-sm">
        {Object.entries(data).map(([key, value]) => (
          <div key={key} className="space-y-1">
            <p className="font-semibold text-foreground">{key.replace(/_/g, " ")}:</p>
            <div className="ml-4">{renderStructuredContent(value)}</div>
          </div>
        ))}
      </div>
    );
  }

  return <span>{String(data)}</span>;
};

const buildSessionsFromHistory = (history: { role: string; message: string }[]): ChatSession[] => {
  const sessions: ChatSession[] = [];
  let currentSession: ChatSession | null = null;
  let index = 0;

  const createNewSession = (firstMessage: Message) => {
    const session: ChatSession = {
      id: `${Date.now()}-${sessions.length}-${index}`,
      title: firstMessage.role === "user" ? firstMessage.content.slice(0, 40) || "Past Chat" : "Past Chat",
      messages: [firstMessage],
      createdAt: Date.now(),
    };
    sessions.push(session);
    return session;
  };

  for (const msg of history) {
    const formatted: Message = {
      id: `${Date.now()}-${index}`,
      role: msg.role === "ai" ? "assistant" : "user",
      content: msg.message,
    };

    if (formatted.role === "user") {
      currentSession = createNewSession(formatted);
    } else if (currentSession) {
      currentSession.messages.push(formatted);
    } else {
      currentSession = createNewSession(formatted);
    }

    index += 1;
  }

  return sessions.length > 0 ? sessions.reverse() : [];
};

const renderMessageContent = (content: string) => {
  const parsed = tryParseJson(content.trim());
  if (parsed !== undefined) {
    return renderStructuredContent(parsed);
  }

  return <div className="whitespace-pre-wrap break-words text-sm">{content}</div>;
};

const OrchestratorPage = () => {
  const { profile } = useProfile();
  const navigate = useNavigate();
  const [sessions, setSessions] = useState<ChatSession[]>([]);
  const [activeId, setActiveId] = useState<string | null>(null);
  const [input, setInput] = useState("");
  const [sidebarOpen, setSidebarOpen] = useState(true);
  const [loading, setLoading] = useState(false);
  const scrollRef = useRef<HTMLDivElement>(null);
  const textareaRef = useRef<HTMLTextAreaElement>(null);

  const activeSession = sessions.find((s) => s.id === activeId) || null;
  const isSavedRef = useRef(false);

  useEffect(() => {
    if (!profile?.email) return;
    if (!isSavedRef.current) {
      isSavedRef.current = true;
      return;
    }
    saveSessions(sessions, profile.email);
  }, [sessions, profile?.email]);

  const createSession = useCallback(() => {
    const s: ChatSession = {
      id: Date.now().toString(),
      title: "New Chat",
      messages: [
        {
          id: "1",
          role: "assistant",
          content: `Hey ${profile?.name || "there"}! I'm Koda, your AI orchestrator. I know you're studying ${
            profile?.major || "something awesome"
          } with a ${profile?.gpa?.toFixed(2) || "great"} GPA.`,
        },
      ],
      createdAt: Date.now(),
    };
    setSessions((prev) => [s, ...prev]);
    setActiveId(s.id);
    setInput("");
  }, [profile]);

  useEffect(() => {
    const email = profile?.email;
    if (!email) {
      setSessions([]);
      setActiveId(null);
      return;
    }

    const saved = loadSessions(email);
    if (saved.length > 0) {
      setSessions(saved);
      setActiveId(saved[0]?.id || null);
      return;
    }

    let active = true;
    const fetchHistory = async () => {
      const token = localStorage.getItem("access_token");
      if (!token) {
        if (active) createSession();
        return;
      }

      try {
        const res = await fetch("http://localhost:8000/history", {
          headers: {
            Authorization: `Bearer ${token}`,
          },
        });

        if (!res.ok) throw new Error("Failed to load history");

        const data = await res.json();
        const messages = (data.history || []).map((m: { role: string; message: string }, index: number) => ({
          id: `${Date.now()}-${index}`,
          role: m.role === "ai" ? "assistant" : "user",
          content: m.message,
        }));

        if (messages.length > 0) {
          const historySessions = buildSessionsFromHistory(data.history || []);

          if (historySessions.length > 0 && active) {
            setSessions(historySessions);
            setActiveId(historySessions[0]?.id || null);
          }
          return;
        }
      } catch (error) {
        console.warn("Unable to load orchestrator history:", error);
      }

      if (active) createSession();
    };

    fetchHistory();
    return () => {
      active = false;
    };
  }, [profile?.email, createSession]);

  useEffect(() => {
    if (sessions.length > 0 && activeId && !sessions.some((s) => s.id === activeId)) {
      setActiveId(sessions[0].id);
    }
  }, [sessions, activeId]);

  useEffect(() => {
    if (scrollRef.current) {
      scrollRef.current.scrollTo({
        top: scrollRef.current.scrollHeight,
        behavior: "smooth",
      });
    }
  }, [activeSession?.messages, loading]);

  useEffect(() => {
    if (textareaRef.current) {
      textareaRef.current.style.height = "auto";
      textareaRef.current.style.height = Math.min(textareaRef.current.scrollHeight, 160) + "px";
    }
  }, [input]);

  const deleteSession = (id: string) => {
    setSessions((prev) => {
      const next = prev.filter((s) => s.id !== id);
      if (activeId === id) setActiveId(next[0]?.id || null);
      if (profile?.email) saveSessions(next, profile.email);
      return next;
    });
  };

  const handleSend = async () => {
    const query = input.trim();
    if (!query || !activeId || loading) return;

    const userMsg: Message = {
      id: Date.now().toString(),
      role: "user",
      content: query,
    };

    // Update session with user message and potentially update title
    setSessions((prev) =>
      prev.map((s) => {
        if (s.id !== activeId) return s;
        const updated = { ...s, messages: [...s.messages, userMsg] };
        if (s.title === "New Chat") updated.title = query.slice(0, 40);
        return updated;
      })
    );

    setInput("");
    if (textareaRef.current) textareaRef.current.style.height = "auto";
    setLoading(true);

    try {
      const token = localStorage.getItem("access_token");
      if (!token) throw new Error("No access token found. Please sign in again.");

      // You can pass the actual activeSession history here if your backend supports it
      const requestBody = { query };

      const res = await fetch("http://localhost:8000/query", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Authorization: `Bearer ${token}`,
        },
        body: JSON.stringify(requestBody),
      });

      const text = await res.text();

      if (!res.ok) {
        let parsedError = null;
        try { parsedError = JSON.parse(text); } catch { parsedError = null; }
        throw new Error(parsedError?.detail || `HTTP ${res.status} ${res.statusText}`);
      }

      const data = JSON.parse(text);
      const responseText = data.answer ?? data.results ?? data.response ?? "No response returned.";

      setSessions((prev) =>
        prev.map((s) =>
          s.id === activeId
            ? {
                ...s,
                messages: [
                  ...s.messages,
                  {
                    id: (Date.now() + 1).toString(),
                    role: "assistant",
                    content: typeof responseText === "string" ? responseText : JSON.stringify(responseText),
                  },
                ],
              }
            : s
        )
      );
    } catch (error: any) {
      const message = error?.message || "Unknown error";
      setSessions((prev) =>
        prev.map((s) =>
          s.id === activeId
            ? {
                ...s,
                messages: [
                  ...s.messages,
                  {
                    id: (Date.now() + 1).toString(),
                    role: "assistant",
                    content: `Sorry, something went wrong connecting to the backend: ${message}`,
                  },
                ],
              }
            : s
        )
      );
    } finally {
      setLoading(false);
    }
  };

  const grouped = sessions.reduce<Record<string, ChatSession[]>>((acc, s) => {
    const key = formatDate(s.createdAt);
    (acc[key] = acc[key] || []).push(s);
    return acc;
  }, {});

  return (
    <div className="h-screen flex overflow-hidden">
      {/* Sidebar */}
      <AnimatePresence>
        {sidebarOpen && (
          <motion.aside
            initial={{ width: 0, opacity: 0 }}
            animate={{ width: 260, opacity: 1 }}
            exit={{ width: 0, opacity: 0 }}
            transition={{ duration: 0.2 }}
            className="h-full flex flex-col border-r border-border/10 bg-card/80 backdrop-blur-xl overflow-hidden shrink-0"
          >
            <div className="p-3 flex items-center justify-between border-b border-border/10">
              <button onClick={() => navigate("/dashboard")} className="text-muted-foreground hover:text-neon transition-colors">
                <ArrowLeft className="w-4 h-4" />
              </button>
              <span className="font-display text-sm font-semibold text-foreground">Past Chats</span>
              <button onClick={createSession} className="text-muted-foreground hover:text-neon transition-colors" title="New Chat">
                <Plus className="w-4 h-4" />
              </button>
            </div>
            <div className="flex-1 overflow-y-auto p-2 space-y-3">
              {Object.entries(grouped).map(([date, chats]) => (
                <div key={date}>
                  <p className="text-[10px] uppercase tracking-wider text-muted-foreground px-2 mb-1 font-body">{date}</p>
                  {chats.map((s) => (
                    <button
                      key={s.id}
                      onClick={() => setActiveId(s.id)}
                      className={`w-full text-left px-3 py-2 rounded-md text-xs font-body truncate flex items-center justify-between group transition-colors ${
                        activeId === s.id
                          ? "bg-neon/10 text-neon border border-neon/20"
                          : "text-muted-foreground hover:bg-secondary/50 border border-transparent"
                      }`}
                    >
                      <span className="flex items-center gap-2 truncate">
                        <MessageSquare className="w-3 h-3 shrink-0" />
                        <span className="truncate">{s.title}</span>
                      </span>
                      <Trash2
                        className="w-3 h-3 opacity-0 group-hover:opacity-60 hover:!opacity-100 hover:text-destructive shrink-0 transition-opacity"
                        onClick={(e) => { e.stopPropagation(); deleteSession(s.id); }}
                      />
                    </button>
                  ))}
                </div>
              ))}
            </div>
          </motion.aside>
        )}
      </AnimatePresence>

      {/* Main chat */}
      <div className="flex-1 flex flex-col min-w-0">
        {/* Top bar */}
        <div className="flex items-center gap-3 px-4 py-3 border-b border-border/10">
          <button onClick={() => setSidebarOpen((p) => !p)} className="text-muted-foreground hover:text-neon transition-colors">
            {sidebarOpen ? <PanelLeftClose className="w-5 h-5" /> : <PanelLeft className="w-5 h-5" />}
          </button>
          {!sidebarOpen && (
            <button onClick={() => navigate("/dashboard")} className="text-muted-foreground hover:text-neon transition-colors">
              <ArrowLeft className="w-5 h-5" />
            </button>
          )}
          <div>
            <h1 className="font-display text-lg font-bold text-foreground">ORCH</h1>
            <p className="text-muted-foreground text-[10px] font-body">AI Orchestrator</p>
          </div>
          <button onClick={createSession} className="ml-auto glow-button !text-xs !px-3 !py-1.5 flex items-center gap-1">
            <Plus className="w-3 h-3" /> New Chat
          </button>
        </div>

        {/* Messages */}
        <div ref={scrollRef} className="flex-1 overflow-y-auto px-4 py-4 space-y-3">
          {activeSession?.messages.map((msg) => (
            <motion.div
              key={msg.id}
              initial={{ opacity: 0, y: 10 }}
              animate={{ opacity: 1, y: 0 }}
              className={`flex ${msg.role === "user" ? "justify-end" : "justify-start"}`}
            >
              <div
                className={`max-w-[75%] rounded-lg px-4 py-2.5 text-sm font-body ${
                  msg.role === "user"
                    ? "bg-neon/20 text-foreground border border-neon/20"
                    : "bg-secondary text-secondary-foreground"
                }`}
              >
                {renderMessageContent(msg.content)}
              </div>
            </motion.div>
          ))}
          {loading && (
            <motion.div initial={{ opacity: 0 }} animate={{ opacity: 1 }} className="flex justify-start">
              <div className="bg-secondary text-secondary-foreground rounded-lg px-4 py-2.5 text-sm font-body">
                <span className="inline-flex gap-1">
                  <span className="w-1.5 h-1.5 rounded-full bg-neon animate-pulse-glow" />
                  <span className="w-1.5 h-1.5 rounded-full bg-neon animate-pulse-glow" style={{ animationDelay: "0.2s" }} />
                  <span className="w-1.5 h-1.5 rounded-full bg-neon animate-pulse-glow" style={{ animationDelay: "0.4s" }} />
                </span>
              </div>
            </motion.div>
          )}
        </div>

        {/* Input */}
        <div className="border-t border-border/10 px-4 py-3">
          <div className="flex gap-2 items-end max-w-3xl mx-auto">
            <textarea
              ref={textareaRef}
              className="glass-input flex-1 resize-none !py-3 min-h-[48px] max-h-[160px]"
              placeholder="Ask about your resume, job search, interview prep, or next steps..."
              value={input}
              rows={1}
              disabled={loading}
              onChange={(e) => setInput(e.target.value)}
              onKeyDown={(e) => {
                if (e.key === "Enter" && !e.shiftKey) {
                  e.preventDefault();
                  handleSend();
                }
              }}
            />
            <button 
              onClick={handleSend} 
              className="glow-button !px-4 !py-3 shrink-0" 
              disabled={!input.trim() || loading}
            >
              <Send className="w-5 h-5" />
            </button>
          </div>
          <p className="text-[10px] text-muted-foreground text-center mt-2 font-body">Shift+Enter for new line</p>
        </div>
      </div>
    </div>
  );
};

export default OrchestratorPage;